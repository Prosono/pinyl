[Unit]
Description=Pinyl webapp
After=network-online.target pcscd.service raspotify.service
Wants=network-online.target

[Service]
User=pinyl
WorkingDirectory=/home/pinyl/pinyl_webapp
EnvironmentFile=/home/pinyl/pinyl_webapp/.env
ExecStart=/home/pinyl/pinyl_webapp/.venv/bin/python /home/pinyl/pinyl_webapp/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
